# ==========================================================================
# Contoh konfigurasi environment untuk backend.
# Salin file ini menjadi `.env` lalu sesuaikan nilainya:
#   cp .env.example .env        (macOS / Linux)
#   Copy-Item .env.example .env (Windows PowerShell)
# ==========================================================================

# Mode debug. WAJIB False di produksi.
# Saat False, aplikasi menolak start bila SECRET_KEY belum diisi.
DEBUG=True

# Koneksi database (default SQLite lokal).
DATABASE_URL=sqlite:///./forbidden_words.db

# Kunci rahasia untuk menandatangani JWT.
# WAJIB diisi dengan nilai acak & panjang (min. 32 karakter) di produksi.
# Contoh membuat nilai acak:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Algoritma dan masa berlaku token JWT.
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Daftar origin frontend yang diizinkan (format list JSON).
CORS_ORIGINS=["http://localhost:3000", "http://127.0.0.1:3000"]
